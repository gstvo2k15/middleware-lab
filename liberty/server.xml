<server description="middleware-lab-open-liberty">
    <featureManager>
        <feature>servlet-6.0</feature>
        <feature>restfulWS-3.1</feature>
        <feature>monitor-1.0</feature>
        <feature>adminCenter-1.0</feature>
        <feature>appSecurity-5.0</feature>
        <feature>transportSecurity-1.0</feature>
    </featureManager>

    <quickStartSecurity userName="admin" userPassword="admin123"/>

    <keyStore id="defaultKeyStore" password="admin123"/>

    <httpEndpoint id="defaultHttpEndpoint"
                  host="*"
                  httpPort="9080"
                  httpsPort="9443"/>

    <webApplication id="sample"
                    location="/config/apps/sample.war"
                    contextRoot="/sample"/>

    <applicationMonitor updateTrigger="mbean"/>
</server>